# Example environment variables for local development.
# Copy this file into .env.local and replace values for your machine.

# Supabase project URL (from Supabase project settings).
VITE_SUPABASE_URL=

# Supabase public anonymous key (safe for frontend use).
VITE_SUPABASE_ANON_KEY=

# Display name used in the app UI.
VITE_APP_NAME=

# Default app language (for example: en, af, fr).
VITE_DEFAULT_LANGUAGE=
